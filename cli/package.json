{
  "name": "poly-glot-ai-cli",
  "version": "1.5.1",
  "description": "AI-powered code comment generation from the command line — Poly-Glot CLI",
  "author": "Harold Moses",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmoses/poly-glot"
  },
  "keywords": [
    "comments",
    "documentation",
    "jsdoc",
    "javadoc",
    "pydoc",
    "ai",
    "openai",
    "anthropic",
    "cli"
  ],
  "bin": {
    "poly-glot": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",

{
  "name": "poly-glot-ai-cli",
  "version": "2.1.11",
  "description": "AI-powered code comments, bug finding, refactoring & test generation — Poly-Glot CLI",
  "author": "Harold Moses",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/poly-glot-ai/poly-glot"
  },
  "keywords": [
    "comments",
    "documentation",
    "jsdoc",
    "javadoc",
    "pydoc",
    "ai",
    "openai",
    "anthropic",
    "cli",
    "bugs",
    "refactor",
    "testing",
    "unit-tests",
    "code-review"
  ],
  "bin": {
    "poly-glot": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "start": "node dist/index.js",
    "postinstall": "node scripts/postinstall.js || true",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.3.0"
  },
  "homepage": "https://poly-glot.ai"
}

{
  "name": "poly-glot",
  "displayName": "Poly-Glot AI",
  "description": "AI code comments for 12 languages — JSDoc, Javadoc, PyDoc, Doxygen, KDoc, why-comments. Powered by GPT-4o & Claude. Free tier + Pro plan.",
  "version": "1.4.0",
  "pricing": "Trial",
  "publisher": "poly-glot-ai",
  "license": "MIT",
  "homepage": "https://poly-glot.ai",
  "bugs": { "url": "https://github.com/hmoses/poly-glot/issues" },
  "galleryBanner": { "color": "#0f1e14", "theme": "dark" },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmoses/poly-glot"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Other",
    "Snippets",
    "Formatters"
  ],
  "keywords": [
    "ai comments",
    "jsdoc generator",
    "javadoc generator",
    "pydoc",
    "doxygen",
    "kdoc",
    "why comments",
    "code documentation",
    "ai documentation",
    "openai",
    "anthropic",
    "claude",
    "gpt-4",
    "code comments",
    "auto comment",
    "typescript comments",
    "python docstring",
    "rust doc",
    "golang doc",
    "poly-glot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "poly-glot.chat",
        "fullName": "Poly-Glot AI",
        "name": "poly-glot",
        "description": "AI code comments — JSDoc, Javadoc, PyDoc, why-comments & more. Type /comment, /why, /both, /explain or just ask.",
        "isSticky": true,
        "commands": [
          {
            "name": "comment",
            "description": "Add doc-comments to selected code or a file (JSDoc, Javadoc, PyDoc, Doxygen…)"
          },
          {
            "name": "why",
            "description": "Add why-comments explaining intent, trade-offs and non-obvious decisions [Pro]"
          },
          {
            "name": "both",
            "description": "Add doc-comments AND why-comments in one pass [Pro]"
          },
          {
            "name": "explain",
            "description": "Deep analysis: complexity, bugs, doc quality score, function breakdown"
          },
          {
            "name": "upgrade",
            "description": "Show Pro plan info and get 3 months free with EARLYBIRD3"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "polyglot.generateComments",
        "title": "Poly-Glot: Add Doc-Comments",
        "icon": "$(comment)"
      },
      {
        "command": "polyglot.whyComments",
        "title": "Poly-Glot: Add Why-Comments",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "polyglot.bothComments",
        "title": "Poly-Glot: Add Doc + Why Comments",
        "icon": "$(file-code)"
      },
      {
        "command": "polyglot.commentFile",
        "title": "Poly-Glot: Comment Entire File",
        "icon": "$(file-code)"
      },
      {
        "command": "polyglot.commentFileFromExplorer",
        "title": "Poly-Glot: Comment This File",
        "icon": "$(file-code)"
      },
      {
        "command": "polyglot.whyFileFromExplorer",
        "title": "Poly-Glot: Add Why-Comments to File",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "polyglot.explainCode",
        "title": "Poly-Glot: Explain Code",
        "icon": "$(search)"
      },
      {
        "command": "polyglot.configureApiKey",
        "title": "Poly-Glot: Configure API Key",
        "icon": "$(key)"
      },
      {
        "command": "polyglot.configureLicenseToken",
        "title": "Poly-Glot: Enter Pro License Token",
        "icon": "$(star)"
      },
      {
        "command": "polyglot.openTemplates",
        "title": "Poly-Glot: Open Templates Sidebar",
        "icon": "$(book)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "polyglot.generateComments",
          "group": "polyglot@1"
        },
        {
          "command": "polyglot.whyComments",
          "group": "polyglot@2"
        },
        {
          "command": "polyglot.bothComments",
          "group": "polyglot@3"
        },
        {
          "command": "polyglot.explainCode",
          "when": "editorHasSelection",
          "group": "polyglot@4"
        }
      ],
      "editor/title": [
        {
          "command": "polyglot.commentFile",
          "when": "editorIsOpen",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "polyglot.commentFileFromExplorer",
          "when": "resourceExtname =~ /\\.(js|ts|jsx|tsx|py|java|cpp|c|cs|go|rs|rb|php|swift|kt)$/",
          "group": "polyglot@1"
        },
        {
          "command": "polyglot.whyFileFromExplorer",
          "when": "resourceExtname =~ /\\.(js|ts|jsx|tsx|py|java|cpp|c|cs|go|rs|rb|php|swift|kt)$/",
          "group": "polyglot@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "polyglot.generateComments",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "editorTextFocus"
      },
      {
        "command": "polyglot.whyComments",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "editorTextFocus"
      },
      {
        "command": "polyglot.bothComments",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorTextFocus"
      },
      {
        "command": "polyglot.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "polyglot-sidebar",
          "title": "Poly-Glot",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "polyglot-sidebar": [
        {
          "type": "webview",
          "id": "polyglot.templatesView",
          "name": "Comment Templates"
        }
      ]
    },
    "configuration": {
      "title": "Poly-Glot AI",
      "properties": {
        "polyglot.provider": {
          "type": "string",
          "default": "openai",
          "enum": ["openai", "anthropic"],
          "enumDescriptions": [
            "Use OpenAI (GPT-4o, GPT-4o-mini)",
            "Use Anthropic (Claude Sonnet, Claude Haiku)"
          ],
          "description": "AI provider for comment generation."
        },
        "polyglot.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model to use. Any valid model ID from your provider."
        },
        "polyglot.commentStyle": {
          "type": "string",
          "default": "auto",
          "enum": ["auto","jsdoc","javadoc","pydoc","doxygen","xmldoc","godoc","rustdoc","rdoc","phpdoc","swift","kotlin"],
          "description": "Comment style. 'auto' detects from file language (recommended)."
        },
        "polyglot.insertInline": {
          "type": "boolean",
          "default": true,
          "description": "Insert comments directly into the editor. If false, opens result in a side panel."
        },
        "polyglot.licenseToken": {
          "type": "string",
          "default": "",
          "description": "Poly-Glot Pro license token. Get yours at poly-glot.ai after subscribing."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}

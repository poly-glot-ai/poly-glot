{
  "name": "poly-glot",
  "displayName": "Poly-Glot Code Comment Library",
  "description": "AI-powered code comment generation for 12 languages — JSDoc, Javadoc, PyDoc, Doxygen, and more.",
  "version": "1.2.0",
  "publisher": "hmoses",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmoses/poly-glot"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "comments",
    "documentation",
    "jsdoc",
    "javadoc",
    "pydoc",
    "ai",
    "openai",
    "anthropic"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "polyglot.generateComments",
        "title": "Poly-Glot: Generate Comments",
        "icon": "$(comment)"
      },
      {
        "command": "polyglot.commentFile",
        "title": "Poly-Glot: Comment Entire File",
        "icon": "$(file-code)"
      },
      {
        "command": "polyglot.commentFileFromExplorer",
        "title": "Poly-Glot: Comment This File",
        "icon": "$(file-code)"
      },
      {
        "command": "polyglot.explainCode",
        "title": "Poly-Glot: Explain Code",
        "icon": "$(search)"
      },
      {
        "command": "polyglot.configureApiKey",
        "title": "Poly-Glot: Configure API Key",
        "icon": "$(key)"
      },
      {
        "command": "polyglot.openTemplates",
        "title": "Poly-Glot: Open Templates Sidebar",
        "icon": "$(book)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "polyglot.generateComments",
          "when": "editorHasSelection",
          "group": "polyglot@1"
        },
        {
          "command": "polyglot.explainCode",
          "when": "editorHasSelection",
          "group": "polyglot@2"
        }
      ],
      "editor/title": [
        {
          "command": "polyglot.commentFile",
          "when": "editorIsOpen",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "polyglot.commentFileFromExplorer",
          "when": "resourceExtname =~ /\\.(js|ts|jsx|tsx|py|java|cpp|c|cs|go|rs|rb|php|swift|kt)$/",
          "group": "polyglot@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "polyglot.generateComments",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "polyglot.commentFile",
        "key": "ctrl+shift+alt+/",
        "mac": "cmd+shift+alt+/",
        "when": "editorTextFocus"
      },
      {
        "command": "polyglot.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "polyglot-sidebar",
          "title": "Poly-Glot",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "polyglot-sidebar": [
        {
          "type": "webview",
          "id": "polyglot.templatesView",
          "name": "Comment Templates"
        }
      ]
    },
    "configuration": {
      "title": "Poly-Glot",
      "properties": {
        "polyglot.provider": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "anthropic"
          ],
          "enumDescriptions": [
            "Use OpenAI (GPT-4o, GPT-4o-mini)",
            "Use Anthropic (Claude Sonnet 4, Claude 3.5 Sonnet)"
          ],
          "description": "AI provider for comment generation"
        },
        "polyglot.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model to use. Set to any valid model ID from your provider."
        },
        "polyglot.commentStyle": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "jsdoc",
            "javadoc",
            "pydoc",
            "doxygen",
            "xmldoc",
            "godoc",
            "rustdoc",
            "rdoc",
            "phpdoc",
            "swift",
            "kotlin"
          ],
          "enumDescriptions": [
            "Auto-detect based on file language (recommended)",
            "JSDoc (JavaScript / TypeScript)",
            "Javadoc (Java)",
            "PyDoc / Google-style (Python)",
            "Doxygen (C / C++)",
            "XML doc comments (C#)",
            "GoDoc (Go)",
            "Rust doc comments (Rust)",
            "RDoc / YARD (Ruby)",
            "PHPDoc (PHP)",
            "Swift markup (Swift)",
            "KDoc (Kotlin)"
          ],
          "description": "Comment style to use. 'auto' detects from file language."
        },
        "polyglot.insertInline": {
          "type": "boolean",
          "default": true,
          "description": "Insert generated comments directly into the editor. If false, shows output in a side panel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}

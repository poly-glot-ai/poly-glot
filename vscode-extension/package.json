{
  "name": "poly-glot",
  "displayName": "Poly-Glot AI",
  "description": "AI-powered code comments & documentation for 12 languages. Auto-generate JSDoc, Javadoc, PyDoc, Doxygen, KDoc, why-comments & docstrings. GPT-4.1, GPT-4o, Claude 4 & custom models. Free tier included.",
  "version": "1.4.7",
  "pricing": "Trial",
  "publisher": "poly-glot-ai",
  "license": "MIT",
  "homepage": "https://poly-glot.ai",
  "bugs": {
    "url": "https://github.com/poly-glot-ai/poly-glot/issues"
  },
  "galleryBanner": {
    "color": "#0f1e14",
    "theme": "dark"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/poly-glot-ai/poly-glot"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "ai comments",
    "code documentation",
    "jsdoc generator",
    "javadoc generator",
    "docstring generator",
    "pydoc",
    "doxygen",
    "code comments",
    "auto comment",
    "comment generator",
    "why comments",
    "code explanation",
    "code analysis",
    "typescript comments",
    "python docstring",
    "rust doc comments",
    "golang doc",
    "kdoc",
    "xmldoc",
    "phpdoc",
    "openai",
    "anthropic",
    "claude",
    "gpt-4",
    "gpt-4.1",
    "copilot chat",
    "ai documentation",
    "ai code review",
    "code generator",
    "poly-glot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "poly-glot.chat",
        "fullName": "Poly-Glot AI",
        "name": "poly-glot",
        "description": "AI code comments \u2014 JSDoc, Javadoc, PyDoc, why-comments & more. Type /comment, /why, /both, /explain or just ask.",
        "isSticky": true,
        "commands": [
          {
            "name": "comment",
            "description": "Add doc-comments to selected code or a file (JSDoc, Javadoc, PyDoc, Doxygen\u2026)"
          },
          {
            "name": "why",
            "description": "Add why-comments explaining intent, trade-offs and non-obvious decisions [Pro]"
          },
          {
            "name": "both",
            "description": "Add doc-comments AND why-comments in one pass [Pro]"
          },
          {
            "name": "explain",
            "description": "Deep analysis: complexity, bugs, doc quality score, function breakdown"
          },
          {
            "name": "upgrade",
            "description": "Show Pro plan info and get 3 months free with EARLYBIRD3"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "polyglot.generateComments",
        "title": "Poly-Glot: Add Doc-Comments",
        "icon": "$(comment)"
      },
      {
        "command": "polyglot.whyComments",
        "title": "Poly-Glot: Add Why-Comments",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "polyglot.bothComments",
        "title": "Poly-Glot: Add Doc + Why Comments",
        "icon": "$(file-code)"
      },
      {
        "command": "polyglot.commentFile",
        "title": "Poly-Glot: Comment Entire File",
        "icon": "$(file-code)"
      },
      {
        "command": "polyglot.commentFileFromExplorer",
        "title": "Poly-Glot: Comment This File",
        "icon": "$(file-code)"
      },
      {
        "command": "polyglot.whyFileFromExplorer",
        "title": "Poly-Glot: Add Why-Comments to File",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "polyglot.explainCode",
        "title": "Poly-Glot: Explain Code",
        "icon": "$(search)"
      },
      {
        "command": "polyglot.configureApiKey",
        "title": "Poly-Glot: Configure API Key",
        "icon": "$(key)"
      },
      {
        "command": "polyglot.configureLicenseToken",
        "title": "Poly-Glot: Enter Pro License Token",
        "icon": "$(star)"
      },
      {
        "command": "polyglot.openTemplates",
        "title": "Poly-Glot: Open Templates Sidebar",
        "icon": "$(book)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "polyglot.generateComments",
          "group": "polyglot@1"
        },
        {
          "command": "polyglot.whyComments",
          "group": "polyglot@2"
        },
        {
          "command": "polyglot.bothComments",
          "group": "polyglot@3"
        },
        {
          "command": "polyglot.explainCode",
          "when": "editorHasSelection",
          "group": "polyglot@4"
        }
      ],
      "editor/title": [
        {
          "command": "polyglot.commentFile",
          "when": "editorIsOpen",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "polyglot.commentFileFromExplorer",
          "when": "resourceExtname =~ /\\.(js|ts|jsx|tsx|py|java|cpp|c|cs|go|rs|rb|php|swift|kt)$/",
          "group": "polyglot@1"
        },
        {
          "command": "polyglot.whyFileFromExplorer",
          "when": "resourceExtname =~ /\\.(js|ts|jsx|tsx|py|java|cpp|c|cs|go|rs|rb|php|swift|kt)$/",
          "group": "polyglot@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "polyglot.generateComments",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "editorTextFocus"
      },
      {
        "command": "polyglot.whyComments",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "editorTextFocus"
      },
      {
        "command": "polyglot.bothComments",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorTextFocus"
      },
      {
        "command": "polyglot.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "polyglot-sidebar",
          "title": "Poly-Glot",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "polyglot-sidebar": [
        {
          "type": "webview",
          "id": "polyglot.templatesView",
          "name": "Comment Templates"
        }
      ]
    },
    "configuration": {
      "title": "Poly-Glot AI",
      "properties": {
        "polyglot.provider": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "anthropic"
          ],
          "enumDescriptions": [
            "Use OpenAI (GPT-4.1, GPT-4o, o3, o1, and more)",
            "Use Anthropic (Claude 4, Claude 3.5, and more)"
          ],
          "description": "AI provider for comment generation."
        },
        "polyglot.model": {
          "type": "string",
          "default": "gpt-4.1-mini",
          "description": "Any valid model ID from your provider \u2014 e.g. gpt-4.1-mini, gpt-4.1-nano, claude-sonnet-4-5, claude-haiku-4-5. Custom/unlisted model IDs are supported."
        },
        "polyglot.commentStyle": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "jsdoc",
            "javadoc",
            "pydoc",
            "doxygen",
            "xmldoc",
            "godoc",
            "rustdoc",
            "rdoc",
            "phpdoc",
            "swift",
            "kotlin"
          ],
          "description": "Comment style. 'auto' detects from file language (recommended)."
        },
        "polyglot.insertInline": {
          "type": "boolean",
          "default": true,
          "description": "Insert comments directly into the editor. If false, opens result in a side panel."
        },
        "polyglot.licenseToken": {
          "type": "string",
          "default": "",
          "description": "Poly-Glot Pro license token. Get yours at poly-glot.ai after subscribing."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  },
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/poly-glot-ai.poly-glot?color=4ade80&label=VS%20Code%20Marketplace",
      "href": "https://marketplace.visualstudio.com/items?itemName=poly-glot-ai.poly-glot",
      "description": "VS Code Marketplace"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/i/poly-glot-ai.poly-glot?color=60b4f6&label=installs",
      "href": "https://marketplace.visualstudio.com/items?itemName=poly-glot-ai.poly-glot",
      "description": "Installs"
    },
    {
      "url": "https://img.shields.io/badge/free%20tier-included-34d399",
      "href": "https://poly-glot.ai/#pricing",
      "description": "Free tier included"
    }
  ],
  "qna": "https://github.com/poly-glot-ai/poly-glot/issues"
}
// Prime Number Generator in Nexus
// Demonstrates loops and conditionals

fn is_prime(n) {
    if n < 2 {
        return false
    }
    for i in 2..n {
        if n % i == 0 {
            return false
        }
    }
    return true
}

print("Prime numbers up to 50:")
for i in 2..51 {
    if is_prime(i) {
        print(i)
    }
}
